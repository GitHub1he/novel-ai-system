# 应用配置
APP_NAME=Novel AI System
APP_VERSION=0.1.0
DEBUG=True

# 数据库配置
# 选项1: PostgreSQL (生产环境推荐)
DATABASE_URL=postgresql://novel_ai_user:novel_ai_password@localhost:5432/novel_ai_db

# 选项2: SQLite (开发环境，无需安装数据库)
# DATABASE_URL=sqlite:///./novel_ai.db

# JWT配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI配置 - 智谱AI (GLM)
# 获取API密钥: https://open.bigmodel.cn/usercenter/apikeys
ZHIPUAI_API_KEY=your-zhipuai-api-key
OPENAI_API_KEY=your-zhipuai-api-key  # 智谱AI也兼容OpenAI格式
OPENAI_API_BASE=https://open.bigmodel.cn/api/paas/v4/
AI_MODEL=glm-4-flash  # 可选模型: glm-4-flash(快/低价), glm-4(标准), glm-4-plus(强力)

# CORS配置
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
